SEA AUDIO PLAYER 

// SEA audio player component with full customization and controls
import {
    useEffect,
    useRef,
    useState,
    useCallback,
    useMemo,
    startTransition,
    type CSSProperties,
    type ChangeEvent,
    type KeyboardEvent,
    type TouchEvent,
} from "react"
import { addPropertyControls, ControlType } from "framer"
import { motion } from "framer-motion"

interface Track {
    title: string
    artist: string
    audioFile: string
    purchaseUrl?: string
    lyrics?: string
}

interface AudioPlayerProps {
    tracks?: Track[]
    audioFile: string
    backgroundColor: string
    accentColor: string
    textColor: string
    progressColor: string
    trackColor: string
    autoPlay: boolean
    loop: boolean
    title: string
    artist: string
    titleFont: CSSProperties
    artistFont: CSSProperties
    playIconColor: string
    blurSize: number
    purchaseUrl: string
    backgroundImage: { src: string; alt?: string }
    darkenAmount: number
    lyrics: string
    showTracklist: boolean
    style?: CSSProperties
}

const formatTime = (time: number) => {
    if (isNaN(time)) return "0:00"
    const minutes = Math.floor(time / 60)
    const seconds = Math.floor(time % 60)
    return `${minutes}:${seconds.toString().padStart(2, "0")}`
}

/**
 * Skeumorphic Audio Player
 *
 * @framerIntrinsicWidth 400
 * @framerIntrinsicHeight 200
 *
 * @framerSupportedLayoutWidth any-prefer-fixed
 * @framerSupportedLayoutHeight auto
 */
export default function AudioPlayer(props: AudioPlayerProps) {
    const {
        tracks = [],
        audioFile = "https://framerusercontent.com/assets/8w3IUatLX9a5JVJ6XPCVuHi94.mp3",
        backgroundColor = "rgba(255, 255, 255, 0)",
        accentColor = "#FFFFFF",
        textColor = "#FFFFFF",
        progressColor = "#000000",
        trackColor = "#CCCCCC",
        loop = false,
        title = "Audio Track",
        artist = "Artist Name",
        titleFont,
        artistFont,
        playIconColor = "#000000",
        blurSize = 20,
        purchaseUrl = "",
        backgroundImage = {
            src: "https://framerusercontent.com/images/GfGkADagM4KEibNcIiRUWlfrR0.jpg",
            alt: "Background",
        },
        darkenAmount = 0,
        lyrics = "",
        showTracklist = false,
    } = props

    const audioRef = useRef<HTMLAudioElement>(null)
    const currentTimeRef = useRef(0)
    const playPromiseRef = useRef<Promise<void> | null>(null)
    const animationFrameRef = useRef<number | null>(null)
    const isSeekingRef = useRef(false)
    const touchStartRef = useRef<{ x: number; y: number } | null>(null)
    const shouldPlayOnTrackLoadRef = useRef(false)
    const shouldReportPlayErrorRef = useRef(false)

    const [isPlaying, setIsPlaying] = useState(false)
    const [currentTime, setCurrentTime] = useState(0)
    const [duration, setDuration] = useState(0)
    const [isSeeking, setIsSeeking] = useState(false)
    const [showCopied, setShowCopied] = useState(false)
    const [showLyrics, setShowLyrics] = useState(false)
    const [trackSelection, setTrackSelection] = useState({
        index: 0,
        version: 0,
    })
    const [isHoveringProgress, setIsHoveringProgress] = useState(false)
    const [isBuffering, setIsBuffering] = useState(false)
    const [hasError, setHasError] = useState(false)
    const [errorMessage, setErrorMessage] = useState("")
    const [isFocused, setIsFocused] = useState(false)
    const [srAnnouncement, setSrAnnouncement] = useState("")

    const isPlaylistMode = tracks.length > 0
    const currentTrackIndex = trackSelection.index

    const currentTrack = useMemo(() => {
        if (isPlaylistMode && tracks[currentTrackIndex]) {
            return tracks[currentTrackIndex]
        }

        return {
            title,
            artist,
            audioFile,
            purchaseUrl,
            lyrics,
        }
    }, [
        isPlaylistMode,
        tracks,
        currentTrackIndex,
        title,
        artist,
        audioFile,
        purchaseUrl,
        lyrics,
    ])

    const currentTrackSource = currentTrack.audioFile?.trim() ?? ""
    const hasAudioFile = currentTrackSource.length > 0
    const trackLoadKey = isPlaylistMode
        ? `${currentTrackIndex}:${trackSelection.version}:${currentTrackSource}`
        : currentTrackSource
    const progressPercentage = duration > 0 ? (currentTime / duration) * 100 : 0

    const clearPendingPlay = useCallback(() => {
        if (playPromiseRef.current) {
            playPromiseRef.current.catch(() => {
                // Ignore interrupted play attempts during source changes.
            })
            playPromiseRef.current = null
        }
    }, [])

    const stopAnimationLoop = useCallback(() => {
        if (animationFrameRef.current !== null) {
            cancelAnimationFrame(animationFrameRef.current)
            animationFrameRef.current = null
        }
    }, [])

    const setSeekingState = useCallback((nextIsSeeking: boolean) => {
        isSeekingRef.current = nextIsSeeking
        startTransition(() => setIsSeeking(nextIsSeeking))
    }, [])

    const isAudioActive = useCallback(() => {
        const audio = audioRef.current
        return Boolean(
            hasAudioFile &&
                (isPlaying || (audio && !audio.paused && !audio.ended))
        )
    }, [hasAudioFile, isPlaying])

    const playAudio = useCallback(
        (showErrorOnFailure: boolean) => {
            const audio = audioRef.current

            if (!audio || !hasAudioFile) {
                return
            }

            clearPendingPlay()

            const playPromise = audio.play()
            playPromiseRef.current = playPromise

            playPromise
                .then(() => {
                    if (playPromiseRef.current === playPromise) {
                        playPromiseRef.current = null
                    }
                })
                .catch((error) => {
                    if (playPromiseRef.current === playPromise) {
                        playPromiseRef.current = null
                    }

                    const errorName = error instanceof Error ? error.name : ""

                    if (errorName === "AbortError") {
                        return
                    }

                    startTransition(() => {
                        setIsPlaying(false)
                        setIsBuffering(false)

                        if (showErrorOnFailure) {
                            setHasError(true)
                            setErrorMessage(
                                errorName === "NotSupportedError"
                                    ? "Audio file not found or format not supported."
                                    : "Playback failed. Please try again."
                            )
                        }
                    })
                })
        },
        [clearPendingPlay, hasAudioFile]
    )

    const pauseAudio = useCallback(() => {
        const audio = audioRef.current
        if (!audio) return

        const pendingPlay = playPromiseRef.current

        if (pendingPlay) {
            pendingPlay
                .catch(() => {
                    // Ignore interrupted play attempts before pausing.
                })
                .finally(() => {
                    audio.pause()
                    if (playPromiseRef.current === pendingPlay) {
                        playPromiseRef.current = null
                    }
                })
            return
        }

        audio.pause()
    }, [])

    const changeTrackIndex = useCallback(
        (
            getNextIndex: (previousIndex: number) => number,
            shouldPlayAfterLoad: boolean,
            shouldReportPlayError: boolean
        ) => {
            if (!isPlaylistMode || tracks.length === 0) return

            shouldPlayOnTrackLoadRef.current = shouldPlayAfterLoad
            shouldReportPlayErrorRef.current = shouldReportPlayError
            clearPendingPlay()

            startTransition(() => {
                setTrackSelection((previousSelection) => {
                    const nextIndex = getNextIndex(previousSelection.index)

                    return {
                        index: nextIndex,
                        version:
                            nextIndex === previousSelection.index
                                ? previousSelection.version + 1
                                : previousSelection.version,
                    }
                })
            })
        },
        [clearPendingPlay, isPlaylistMode, tracks.length]
    )

    const seekTo = useCallback(
        (time: number) => {
            const audio = audioRef.current
            if (!audio || !hasAudioFile || duration <= 0) return

            const nextTime = Math.max(0, Math.min(duration, time))
            audio.currentTime = nextTime
            currentTimeRef.current = nextTime
            startTransition(() => setCurrentTime(nextTime))
        },
        [duration, hasAudioFile]
    )

    // Announce playback state changes to screen readers
    useEffect(() => {
        if (isPlaying) {
            setSrAnnouncement(
                `Playing ${currentTrack.title} by ${currentTrack.artist}`
            )
        } else if (!isPlaying && currentTime > 0) {
            setSrAnnouncement(`Paused at ${formatTime(currentTime)}`)
        }
    }, [isPlaying, currentTrack.title, currentTrack.artist, currentTime])

    // Announce buffering state to screen readers
    useEffect(() => {
        if (isBuffering) {
            setSrAnnouncement("Buffering audio...")
        }
    }, [isBuffering])

    // Announce track changes to screen readers
    useEffect(() => {
        if (isPlaylistMode) {
            setSrAnnouncement(
                `Track ${currentTrackIndex + 1} of ${tracks.length}: ${currentTrack.title} by ${currentTrack.artist}`
            )
        }
    }, [
        currentTrackIndex,
        isPlaylistMode,
        tracks.length,
        currentTrack.title,
        currentTrack.artist,
    ])

    // Announce missing audio and errors to screen readers
    useEffect(() => {
        if (!hasAudioFile) {
            setSrAnnouncement("Audio file missing")
        } else if (hasError && errorMessage) {
            setSrAnnouncement(`Error: ${errorMessage}`)
        }
    }, [hasAudioFile, hasError, errorMessage])

    // Keep the selected playlist index valid if the track array changes.
    useEffect(() => {
        if (!isPlaylistMode && currentTrackIndex !== 0) {
            startTransition(() =>
                setTrackSelection((previousSelection) => ({
                    index: 0,
                    version: previousSelection.version + 1,
                }))
            )
            return
        }

        if (isPlaylistMode && currentTrackIndex >= tracks.length) {
            startTransition(() =>
                setTrackSelection((previousSelection) => ({
                    index: 0,
                    version: previousSelection.version + 1,
                }))
            )
        }
    }, [currentTrackIndex, isPlaylistMode, tracks.length])

    // Smooth 60fps progress bar using requestAnimationFrame
    useEffect(() => {
        const audioNode = audioRef.current
        if (!audioNode) return

        let lastUpdateTime = 0

        const updateProgress = (timestamp: number) => {
            if (!isSeekingRef.current) {
                currentTimeRef.current = audioNode.currentTime

                if (timestamp - lastUpdateTime >= 100) {
                    setCurrentTime(audioNode.currentTime)
                    lastUpdateTime = timestamp
                }
            }

            if (!audioNode.paused && !audioNode.ended) {
                animationFrameRef.current =
                    requestAnimationFrame(updateProgress)
            } else {
                animationFrameRef.current = null
            }
        }

        const handlePlay = () => {
            setIsPlaying(true)
            setIsBuffering(false)

            if (animationFrameRef.current === null) {
                animationFrameRef.current =
                    requestAnimationFrame(updateProgress)
            }
        }

        const handlePause = () => {
            setIsPlaying(false)
            stopAnimationLoop()
        }

        const handleEnded = () => {
            setIsPlaying(false)
            stopAnimationLoop()

            if (isPlaylistMode) {
                changeTrackIndex(
                    (previousIndex) =>
                        previousIndex < tracks.length - 1
                            ? previousIndex + 1
                            : 0,
                    true,
                    false
                )
            }
        }

        const handleLoadedMetadata = () => {
            const nextDuration = Number.isFinite(audioNode.duration)
                ? audioNode.duration
                : 0
            startTransition(() => setDuration(nextDuration))
        }

        const updateTime = () => {
            if (!isSeekingRef.current) {
                currentTimeRef.current = audioNode.currentTime
                setCurrentTime(audioNode.currentTime)
            }
        }

        const clearBuffering = () => {
            startTransition(() => setIsBuffering(false))
        }

        const handleWaiting = () => {
            startTransition(() => setIsBuffering(true))
        }

        const handleError = () => {
            startTransition(() => {
                setIsBuffering(false)
                setIsPlaying(false)
                setHasError(true)

                const error = audioNode.error
                if (error) {
                    switch (error.code) {
                        case error.MEDIA_ERR_ABORTED:
                            setErrorMessage(
                                "Playback was aborted. Please try again."
                            )
                            break
                        case error.MEDIA_ERR_NETWORK:
                            setErrorMessage(
                                "Network error. Check your connection and try again."
                            )
                            break
                        case error.MEDIA_ERR_DECODE:
                            setErrorMessage(
                                "Audio file is corrupted or unsupported."
                            )
                            break
                        case error.MEDIA_ERR_SRC_NOT_SUPPORTED:
                            setErrorMessage(
                                "Audio file not found or format not supported."
                            )
                            break
                        default:
                            setErrorMessage(
                                "Failed to load audio. Please try again."
                            )
                    }
                } else {
                    setErrorMessage("Failed to load audio. Please try again.")
                }
            })
        }

        const handleLoadStart = () => {
            startTransition(() => {
                setHasError(false)
                setErrorMessage("")
            })
        }

        audioNode.addEventListener("play", handlePlay)
        audioNode.addEventListener("pause", handlePause)
        audioNode.addEventListener("ended", handleEnded)
        audioNode.addEventListener("loadedmetadata", handleLoadedMetadata)
        audioNode.addEventListener("timeupdate", updateTime)
        audioNode.addEventListener("waiting", handleWaiting)
        audioNode.addEventListener("stalled", handleWaiting)
        audioNode.addEventListener("canplay", clearBuffering)
        audioNode.addEventListener("canplaythrough", clearBuffering)
        audioNode.addEventListener("playing", clearBuffering)
        audioNode.addEventListener("error", handleError)
        audioNode.addEventListener("loadstart", handleLoadStart)

        return () => {
            stopAnimationLoop()
            audioNode.removeEventListener("play", handlePlay)
            audioNode.removeEventListener("pause", handlePause)
            audioNode.removeEventListener("ended", handleEnded)
            audioNode.removeEventListener(
                "loadedmetadata",
                handleLoadedMetadata
            )
            audioNode.removeEventListener("timeupdate", updateTime)
            audioNode.removeEventListener("waiting", handleWaiting)
            audioNode.removeEventListener("stalled", handleWaiting)
            audioNode.removeEventListener("canplay", clearBuffering)
            audioNode.removeEventListener("canplaythrough", clearBuffering)
            audioNode.removeEventListener("playing", clearBuffering)
            audioNode.removeEventListener("error", handleError)
            audioNode.removeEventListener("loadstart", handleLoadStart)
        }
    }, [changeTrackIndex, isPlaylistMode, stopAnimationLoop, tracks.length])

    // Reset playback state when the active source changes. Only queued track
    // changes continue playback; initial page load never starts playback.
    useEffect(() => {
        const audio = audioRef.current
        if (!audio) return

        const shouldPlayAfterLoad = shouldPlayOnTrackLoadRef.current
        const shouldReportPlayError = shouldReportPlayErrorRef.current
        shouldPlayOnTrackLoadRef.current = false
        shouldReportPlayErrorRef.current = false

        clearPendingPlay()
        stopAnimationLoop()
        audio.pause()
        audio.currentTime = 0
        currentTimeRef.current = 0
        setSeekingState(false)

        startTransition(() => {
            setCurrentTime(0)
            setDuration(0)
            setIsPlaying(false)
            setShowLyrics(false)
            setHasError(false)
            setErrorMessage("")
            setIsBuffering(false)
        })

        if (!hasAudioFile) {
            audio.removeAttribute("src")
            audio.load()
            return
        }

        audio.load()

        if (shouldPlayAfterLoad) {
            playAudio(shouldReportPlayError)
        }
    }, [
        clearPendingPlay,
        hasAudioFile,
        playAudio,
        setSeekingState,
        stopAnimationLoop,
        trackLoadKey,
    ])

    const togglePlay = useCallback(() => {
        if (!hasAudioFile) {
            setSrAnnouncement("Audio file missing")
            return
        }

        if (isPlaying) {
            pauseAudio()
        } else {
            startTransition(() => {
                setHasError(false)
                setErrorMessage("")
            })
            playAudio(true)
        }
    }, [hasAudioFile, isPlaying, pauseAudio, playAudio])

    const handleSeek = useCallback(
        (event: ChangeEvent<HTMLInputElement>) => {
            seekTo(parseFloat(event.target.value))
        },
        [seekTo]
    )

    const handleSeekStart = useCallback(() => {
        if (!hasAudioFile) return
        setSeekingState(true)
    }, [hasAudioFile, setSeekingState])

    const handleSeekEnd = useCallback(() => {
        setSeekingState(false)
    }, [setSeekingState])

    const handleTouchStart = useCallback(
        (event: TouchEvent<HTMLInputElement>) => {
            const touch = event.touches[0]
            if (!touch || !hasAudioFile) return
            touchStartRef.current = { x: touch.clientX, y: touch.clientY }
        },
        [hasAudioFile]
    )

    const handleTouchEnd = useCallback(() => {
        touchStartRef.current = null
        setSeekingState(false)
    }, [setSeekingState])

    const handleTouchMove = useCallback(
        (event: TouchEvent<HTMLInputElement>) => {
            const touch = event.touches[0]
            const touchStart = touchStartRef.current
            if (!touch || !touchStart || !hasAudioFile || duration <= 0) return

            const deltaX = touch.clientX - touchStart.x
            const deltaY = touch.clientY - touchStart.y

            if (!isSeekingRef.current) {
                const movedEnough = Math.abs(deltaX) > 6 || Math.abs(deltaY) > 6
                const isHorizontalDrag = Math.abs(deltaX) >= Math.abs(deltaY)

                if (!movedEnough || !isHorizontalDrag) {
                    return
                }

                setSeekingState(true)
            }

            event.preventDefault()

            const rect = event.currentTarget.getBoundingClientRect()
            const x = touch.clientX - rect.left
            const percentage = Math.max(0, Math.min(1, x / rect.width))
            seekTo(percentage * duration)
        },
        [duration, hasAudioFile, seekTo, setSeekingState]
    )

    const handleProgressKeyDown = useCallback(
        (event: KeyboardEvent<HTMLInputElement>) => {
            const audio = audioRef.current
            if (!audio || !hasAudioFile) return

            if (event.key === "ArrowRight" || event.key === "ArrowLeft") {
                event.preventDefault()
                const step = event.shiftKey ? 30 : 5
                const nextTime =
                    event.key === "ArrowRight"
                        ? audio.currentTime + step
                        : audio.currentTime - step
                seekTo(nextTime)
            } else if (event.key === "Home") {
                event.preventDefault()
                seekTo(0)
            } else if (event.key === "End") {
                event.preventDefault()
                seekTo(duration)
            }
        },
        [duration, hasAudioFile, seekTo]
    )

    const skipBackward = useCallback(() => {
        const audio = audioRef.current
        if (!audio) return
        seekTo(audio.currentTime - 10)
    }, [seekTo])

    const skipForward = useCallback(() => {
        const audio = audioRef.current
        if (!audio) return
        seekTo(audio.currentTime + 10)
    }, [seekTo])

    const previousTrack = useCallback(() => {
        if (!isPlaylistMode) return

        changeTrackIndex(
            (previousIndex) =>
                previousIndex > 0 ? previousIndex - 1 : tracks.length - 1,
            isAudioActive(),
            true
        )
    }, [changeTrackIndex, isAudioActive, isPlaylistMode, tracks.length])

    const nextTrack = useCallback(() => {
        if (!isPlaylistMode) return

        changeTrackIndex(
            (previousIndex) =>
                previousIndex < tracks.length - 1 ? previousIndex + 1 : 0,
            isAudioActive(),
            true
        )
    }, [changeTrackIndex, isAudioActive, isPlaylistMode, tracks.length])

    const handleShare = useCallback(() => {
        if (typeof window === "undefined") return

        const shareText = `${currentTrack.title} by ${currentTrack.artist}`
        const shareUrl = window.location.href

        if (navigator.share) {
            navigator
                .share({
                    title: shareText,
                    url: shareUrl,
                })
                .catch((error) => {
                    console.log("Share failed:", error)
                })
        } else {
            navigator.clipboard.writeText(shareUrl).then(() => {
                startTransition(() => setShowCopied(true))
                setTimeout(() => {
                    startTransition(() => setShowCopied(false))
                }, 2000)
            })
        }
    }, [currentTrack.title, currentTrack.artist])

    const handleTrackClick = useCallback(
        (index: number) => {
            if (index === currentTrackIndex) return

            changeTrackIndex(() => index, isAudioActive(), true)
        },
        [changeTrackIndex, currentTrackIndex, isAudioActive]
    )

    const handleTrackKeyDown = useCallback(
        (event: KeyboardEvent<HTMLDivElement>, index: number) => {
            if (event.key !== "Enter" && event.key !== " ") return

            event.preventDefault()
            handleTrackClick(index)
        },
        [handleTrackClick]
    )

    const retryAudio = useCallback(() => {
        const audio = audioRef.current
        if (!audio || !hasAudioFile) return

        clearPendingPlay()

        startTransition(() => {
            setHasError(false)
            setErrorMessage("")
            setIsBuffering(true)
        })

        audio.load()
        playAudio(true)
    }, [clearPendingPlay, hasAudioFile, playAudio])

    const toggleLyrics = useCallback(() => {
        startTransition(() => setShowLyrics((previousValue) => !previousValue))
    }, [])

    // Add global keyboard shortcuts
    useEffect(() => {
        if (typeof window === "undefined") return

        const handleGlobalKeyDown = (event: globalThis.KeyboardEvent) => {
            if (
                event.target instanceof HTMLInputElement ||
                event.target instanceof HTMLTextAreaElement
            ) {
                return
            }

            if (event.key === " " || event.key === "k" || event.key === "K") {
                event.preventDefault()
                togglePlay()
            } else if (event.key === "ArrowLeft" && !isFocused) {
                event.preventDefault()
                skipBackward()
            } else if (event.key === "ArrowRight" && !isFocused) {
                event.preventDefault()
                skipForward()
            } else if (event.key === "j" || event.key === "J") {
                event.preventDefault()
                skipBackward()
            } else if (event.key === "l" || event.key === "L") {
                event.preventDefault()
                skipForward()
            } else if (
                (event.key === "n" || event.key === "N") &&
                isPlaylistMode
            ) {
                event.preventDefault()
                nextTrack()
            } else if (
                (event.key === "p" || event.key === "P") &&
                isPlaylistMode
            ) {
                event.preventDefault()
                previousTrack()
            }
        }

        window.addEventListener("keydown", handleGlobalKeyDown)
        return () => window.removeEventListener("keydown", handleGlobalKeyDown)
    }, [
        togglePlay,
        skipBackward,
        skipForward,
        nextTrack,
        previousTrack,
        isPlaylistMode,
        isFocused,
    ])

    return (
        <div
            className="sea-audio-player-wrapper"
            style={{
                ...props.style,
                position: "relative",
                width: "100%",
                height: "100%",
                backgroundColor: backgroundColor,
                backdropFilter: `blur(${blurSize}px)`,
                WebkitBackdropFilter: `blur(${blurSize}px)`,
                borderRadius: 16,
                padding: 24,
                boxShadow:
                    "inset 0 0.5px 0.5px rgba(255,255,255,0.1), 0 1px 4px rgba(0,0,0,0.08)",
                display: "flex",
                flexDirection: "column",
                gap: 16,
                overflow: "hidden",
            }}
            role="region"
            aria-label="Audio player"
        >
            {/* Screen reader live region for announcements */}
            <div
                role="status"
                aria-live="polite"
                aria-atomic="true"
                style={{
                    position: "absolute",
                    left: "-10000px",
                    width: "1px",
                    height: "1px",
                    overflow: "hidden",
                }}
            >
                {srAnnouncement}
            </div>

            {backgroundImage?.src && (
                <div
                    style={{
                        position: "absolute",
                        top: 0,
                        left: 0,
                        width: "100%",
                        height: "100%",
                        backgroundImage: `url(${backgroundImage.src})`,
                        backgroundSize: "cover",
                        backgroundPosition: "center",
                        filter: `blur(${blurSize}px)`,
                        zIndex: 0,
                        borderRadius: 16,
                    }}
                />
            )}
            {backgroundImage?.src && darkenAmount > 0 && (
                <div
                    style={{
                        position: "absolute",
                        top: 0,
                        left: 0,
                        width: "100%",
                        height: "100%",
                        backgroundColor: `rgba(0, 0, 0, ${darkenAmount / 100})`,
                        zIndex: 0,
                        borderRadius: 16,
                    }}
                />
            )}
            <div
                style={{
                    position: "relative",
                    zIndex: 1,
                    display: "flex",
                    flexDirection: "column",
                    gap: 16,
                    width: "100%",
                }}
            >
                <audio
                    ref={audioRef}
                    src={hasAudioFile ? currentTrackSource : undefined}
                    loop={isPlaylistMode ? false : loop}
                />

                {!hasAudioFile && (
                    <motion.div
                        initial={{ opacity: 0, y: -10 }}
                        animate={{ opacity: 1, y: 0 }}
                        exit={{ opacity: 0, y: -10 }}
                        transition={{
                            type: "spring",
                            stiffness: 300,
                            damping: 30,
                        }}
                        style={{
                            padding: 16,
                            borderRadius: 8,
                            backgroundColor: "rgba(255, 59, 48, 0.15)",
                            border: "1px solid rgba(255, 59, 48, 0.3)",
                            display: "flex",
                            alignItems: "center",
                            justifyContent: "center",
                            gap: 8,
                        }}
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#FF3B30"
                            strokeWidth="2"
                        >
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
